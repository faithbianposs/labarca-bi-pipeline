dim_t AS (SELECT * FROM "labarca_dw"."staging_marts"."dim_tiempo"),
dim_p AS (SELECT * FROM "labarca_dw"."staging_marts"."dim_producto"),
dim_c AS (SELECT * FROM "labarca_dw"."staging_marts"."dim_cliente"),
dim_d AS (SELECT * FROM "labarca_dw"."staging_marts"."dim_pedido")

SELECT
    b.id_venta,
    dim_t.id_tiempo,
    dim_p.id_producto,
    dim_c.id_cliente,
    dim_d.id_pedido,
    b.hora,
    b.turno,
    b.tipo_dia,
    b.cantidad,
    b.precio_unitario,
    b.subtotal,
    b.total_venta,
    b.tiempo_preparacion,
    b.diferencia_caja,
    CASE WHEN b.error_caja = 'Sí' THEN 1 ELSE 0 END AS tiene_error_caja

FROM base b
LEFT JOIN dim_t ON dim_t.fecha          = b.fecha
LEFT JOIN dim_p ON dim_p.producto       = b.producto
LEFT JOIN dim_c ON dim_c.cliente_nombre = b.cliente_nombre
LEFT JOIN dim_d ON dim_d.tipo_pedido    = b.tipo_pedido
               AND dim_d.metodo_pago    = b.metodo_pago
               AND dim_d.caja           = b.caja
  );
  
